{
  "name": "radio-flow",
  "version": "0.1.0",
  "description": "Radio Playout Player",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.radioautomation.radio-flow",
    "productName": "RadioFlow",
    "mac": {
      "category": "public.app-category.music",
      "target": "dmg",
      "icon": "icon.icns"
    },
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis"
    },
    "asar": false,
    "files": [
      "main.js",
      "player.html",
      "hotkeys.html",
      "preload-hotkeys.js",
      "icons",
      "logo.svg",
      "radio-flow.png"
    ]
  }
}
