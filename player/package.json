{
  "name": "radio-player",
  "version": "0.1.0",
  "description": "Radio Playout Player",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.waelson.radio-player",
    "productName": "Player",
    "mac": {
      "category": "public.app-category.music",
      "target": "dmg",
      "icon": "icon.icns"
    },
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "main.js",
      "player.html"
    ]
  }
}
